# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Lock file — excluded so deployment servers regenerate for their own OS/platform
package-lock.json

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local database schema scripts (contains project-specific SQL, keep local only)
schema.sql
schema_tables.sql
schema_batch1.sql
schema_batch2.sql
schema_batch3.sql

# Python scripts (utility only, not part of the app)
src/lib/generate_sql.py
